---
// 最近瀏覽文章顯示元件（About 頁面用）
// 資料由 BlogPost.astro 的 script 寫入 localStorage
---

<section class="recently-read" id="recently-read" hidden>
	<h3 class="rr-heading">你最近讀了</h3>
	<ul class="rr-list" id="rr-list"></ul>
	<a href="/blog/archive" class="rr-more">查看完整歸檔 →</a>
</section>

<script>
(function () {
	const KEY = 'recently-read';
	const MAX = 5;

	interface ReadItem {
		id: string;
		title: string;
		category?: string;
		url: string;
		date: number;
	}

	function getItems(): ReadItem[] {
		try {
			return JSON.parse(localStorage.getItem(KEY) ?? '[]');
		} catch {
			return [];
		}
	}

	const items = getItems().slice(0, MAX);
	if (items.length === 0) return;

	const section = document.getElementById('recently-read');
	const list = document.getElementById('rr-list');
	if (!section || !list) return;

	list.innerHTML = items.map(item => `
		<li>
			<a href="${item.url}" class="rr-item">
				${item.category ? `<span class="rr-cat">${item.category}</span>` : ''}
				<span class="rr-title">${item.title}</span>
			</a>
		</li>
	`).join('');

	section.hidden = false;
})();
</script>

<style>
.recently-read {
	margin-top: 1.5rem;
	padding-top: 1.5rem;
	border-top: 1px solid var(--color-border);
}

.rr-heading {
	font-size: 0.72rem;
	font-weight: 800;
	letter-spacing: 0.1em;
	text-transform: uppercase;
	color: var(--color-text-muted);
	margin: 0 0 0.85rem;
}

.rr-list {
	list-style: none;
	padding: 0;
	margin: 0 0 0.85rem;
	display: flex;
	flex-direction: column;
	gap: 0.35rem;
}

.rr-item {
	display: flex;
	flex-direction: column;
	gap: 0.1rem;
	font-size: 0.85rem;
	color: var(--color-text-secondary);
	text-decoration: none;
	padding: 0.4rem 0.6rem;
	border-radius: 7px;
	transition: all 0.15s ease;
	line-height: 1.4;
}
.rr-item:hover {
	background: var(--color-accent-light);
	color: var(--color-accent);
	text-decoration: none;
}

.rr-cat {
	font-size: 0.68rem;
	font-weight: 700;
	color: var(--color-accent);
	letter-spacing: 0.03em;
}
[data-theme="dark"] .rr-cat { color: #60a5fa; }

.rr-title {
	font-weight: 600;
	color: var(--color-text-secondary);
	display: -webkit-box;
	-webkit-line-clamp: 1;
	-webkit-box-orient: vertical;
	overflow: hidden;
}
.rr-item:hover .rr-title { color: var(--color-accent); }

.rr-more {
	font-size: 0.8rem;
	font-weight: 600;
	color: var(--color-accent);
	text-decoration: none;
}
.rr-more:hover { text-decoration: underline; }
</style>
