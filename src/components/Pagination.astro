---
interface Props {
	currentPage: number;
	totalPages: number;
}

const { currentPage, totalPages } = Astro.props;

function pageUrl(page: number) {
	return page === 1 ? '/blog/' : `/blog/page/${page}/`;
}

// Show at most 5 page numbers centered around currentPage
const delta = 2;
const start = Math.max(1, currentPage - delta);
const end = Math.min(totalPages, currentPage + delta);
const pages = Array.from({ length: end - start + 1 }, (_, i) => start + i);
---

{totalPages > 1 && (
	<nav class="pagination" aria-label="分頁導覽">
		<!-- Prev -->
		{currentPage > 1 ? (
			<a href={pageUrl(currentPage - 1)} class="page-btn nav-btn" aria-label="上一頁">‹</a>
		) : (
			<span class="page-btn nav-btn disabled" aria-disabled="true">‹</span>
		)}

		<!-- First page if not in range -->
		{start > 1 && (
			<>
				<a href={pageUrl(1)} class="page-btn">1</a>
				{start > 2 && <span class="ellipsis">…</span>}
			</>
		)}

		<!-- Page numbers -->
		{pages.map((p) => (
			p === currentPage
				? <span class="page-btn active" aria-current="page">{p}</span>
				: <a href={pageUrl(p)} class="page-btn">{p}</a>
		))}

		<!-- Last page if not in range -->
		{end < totalPages && (
			<>
				{end < totalPages - 1 && <span class="ellipsis">…</span>}
				<a href={pageUrl(totalPages)} class="page-btn">{totalPages}</a>
			</>
		)}

		<!-- Next -->
		{currentPage < totalPages ? (
			<a href={pageUrl(currentPage + 1)} class="page-btn nav-btn" aria-label="下一頁">›</a>
		) : (
			<span class="page-btn nav-btn disabled" aria-disabled="true">›</span>
		)}
	</nav>
)}

<style>
.pagination {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 0.35rem;
	margin-top: 3.5rem;
	flex-wrap: wrap;
}

.page-btn {
	display: inline-flex;
	align-items: center;
	justify-content: center;
	min-width: 2.25rem;
	height: 2.25rem;
	padding: 0 0.5rem;
	border-radius: 8px;
	font-size: 0.9rem;
	font-weight: 600;
	text-decoration: none;
	border: 1px solid var(--color-border);
	background: var(--color-bg-card);
	color: var(--color-text-primary);
	transition: all 0.15s ease;
}
.page-btn:hover:not(.active):not(.disabled) {
	border-color: #93c5fd;
	background: var(--color-accent-light);
	color: var(--color-accent);
	text-decoration: none;
}
.page-btn.active {
	background: var(--color-accent);
	color: #fff;
	border-color: var(--color-accent);
}
.page-btn.disabled {
	opacity: 0.35;
	cursor: not-allowed;
}
.nav-btn {
	font-size: 1.1rem;
}

.ellipsis {
	font-size: 0.9rem;
	color: var(--color-text-muted);
	padding: 0 0.15rem;
	user-select: none;
}
</style>
