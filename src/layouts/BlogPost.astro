---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Breadcrumb from '../components/Breadcrumb.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORY_EMOJI } from '../consts';

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
	readingTime?: number;
	wordCount?: number;
	relatedPosts?: CollectionEntry<'blog'>[];
};

const {
	title,
	description,
	pubDate,
	updatedDate,
	heroImage,
	category,
	subcategories,
	tags,
	prevPost,
	nextPost,
	readingTime,
	wordCount,
	relatedPosts,
} = Astro.props;

---

<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} image={heroImage} pubDate={pubDate} updatedDate={updatedDate} />
	</head>

	<body>
		<!-- 閱讀進度條 -->
		<div id="reading-progress" role="progressbar" aria-label="閱讀進度"></div>

		<Header />
		<main>
			<div class="post-layout">
				<article>
					<!-- Breadcrumb -->
					<Breadcrumb items={[
						{ label: '首頁', href: '/' },
						{ label: '文章', href: '/blog' },
						...(category ? [{ label: category, href: `/blog/category/${encodeURIComponent(category)}` }] : []),
						{ label: title },
					]} />

					<!-- Hero Image -->
					{heroImage && (
						<div class="hero-image">
							<img src={heroImage} alt={title} loading="eager" />
						</div>
					)}

					<!-- Title Section -->
					<div class="title-section">
						<div class="meta-badges">
							{category && (
								<a href={`/blog/category/${encodeURIComponent(category)}`} class="badge badge-cat">{category}</a>
							)}
							{subcategories && subcategories.map((sub) => (
								<span class="badge badge-sub">{sub}</span>
							))}
						</div>

						<h1>{title}</h1>

						<div class="date-row">
							<span class="date">
								📅 <FormattedDate date={pubDate} />
							</span>
							{updatedDate && (
								<span class="date updated">
									・ 更新於 <FormattedDate date={updatedDate} />
								</span>
							)}
							{readingTime && (
								<span class="reading-time">・ 約 {readingTime} 分鐘閱讀</span>
							)}
						{wordCount && wordCount > 0 && (
								<span class="word-count">・ {wordCount.toLocaleString()} 字</span>
							)}
						</div>

						{tags && tags.length > 0 && (
							<div class="tag-row">
								{tags.map((tag) => (
									<a href={`/blog/tag/${encodeURIComponent(tag)}`} class="badge badge-tag">{tag}</a>
								))}
							</div>
						)}
					</div>

					<!-- Post Body -->
					<div class="prose">
						<slot />
					</div>

					<!-- 分享按鈕 -->
					<div class="share-section">
						<span class="share-label">分享文章</span>
						<div class="share-buttons">
							<a id="share-twitter" class="share-btn share-twitter" href="#" target="_blank" rel="noopener" aria-label="分享到 Twitter">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M18.244 2.25h3.308l-7.227 8.26 8.502 11.24H16.17l-4.714-6.231-5.401 6.231H2.744l7.73-8.835L1.254 2.25H8.08l4.253 5.622zm-1.161 17.52h1.833L7.084 4.126H5.117z"/></svg>
								Twitter
							</a>
							<a id="share-facebook" class="share-btn share-facebook" href="#" target="_blank" rel="noopener" aria-label="分享到 Facebook">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M24 12.073c0-6.627-5.373-12-12-12s-12 5.373-12 12c0 5.99 4.388 10.954 10.125 11.854v-8.385H7.078v-3.47h3.047V9.43c0-3.007 1.792-4.669 4.533-4.669 1.312 0 2.686.235 2.686.235v2.953H15.83c-1.491 0-1.956.925-1.956 1.874v2.25h3.328l-.532 3.47h-2.796v8.385C19.612 23.027 24 18.062 24 12.073z"/></svg>
								Facebook
							</a>
							<a id="share-line" class="share-btn share-line" href="#" target="_blank" rel="noopener" aria-label="分享到 LINE">
								<svg width="18" height="18" viewBox="0 0 24 24" fill="currentColor"><path d="M19.365 9.863c.349 0 .63.285.63.631 0 .345-.281.63-.63.63H17.61v1.125h1.755c.349 0 .63.283.63.63 0 .344-.281.629-.63.629h-2.386c-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63h2.386c.349 0 .63.285.63.63 0 .349-.281.63-.63.63H17.61v1.125h1.755zm-3.855 3.016c0 .27-.174.51-.432.596-.064.021-.133.031-.199.031-.211 0-.391-.09-.51-.25l-2.443-3.317v2.94c0 .344-.279.629-.631.629-.346 0-.626-.285-.626-.629V8.108c0-.27.173-.51.43-.595.06-.023.136-.033.194-.033.195 0 .375.104.495.254l2.462 3.33V8.108c0-.345.282-.63.63-.63.345 0 .63.285.63.63v4.771zm-5.741 0c0 .344-.282.629-.631.629-.345 0-.627-.285-.627-.629V8.108c0-.345.282-.63.627-.63.349 0 .631.285.631.63v4.771zm-2.466.629H4.917c-.345 0-.63-.285-.63-.629V8.108c0-.345.285-.63.63-.63.348 0 .63.285.63.63v4.141h1.756c.348 0 .629.283.629.63 0 .344-.281.629-.629.629M24 10.314C24 4.943 18.615.572 12 .572S0 4.943 0 10.314c0 4.811 4.27 8.842 10.035 9.608.391.082.923.258 1.058.59.12.301.079.766.038 1.08l-.164 1.02c-.045.301-.24 1.186 1.049.645 1.291-.539 6.916-4.078 9.436-6.975C23.176 14.393 24 12.458 24 10.314"/></svg>
								LINE
							</a>
						</div>
					</div>

					<!-- Broken image handler -->
					<script>
					document.querySelectorAll('.prose img').forEach((img) => {
						const el = img as HTMLImageElement;
						if (el.complete && el.naturalWidth === 0) {
							el.replaceWith(makePlaceholder(el.alt));
						} else {
							el.addEventListener('error', () => el.replaceWith(makePlaceholder(el.alt)));
						}
					});
					function makePlaceholder(alt: string) {
						const div = document.createElement('div');
						div.className = 'broken-img-placeholder';
						div.innerHTML = `<span class="broken-img-icon">🖼️</span><span class="broken-img-alt">${alt || '圖片無法顯示'}</span>`;
						return div;
					}
					</script>

					<!-- 程式碼複製按鈕 -->
				<script>
				(function () {
					document.querySelectorAll('.prose pre').forEach((pre) => {
						const btn = document.createElement('button');
						btn.className = 'copy-btn';
						btn.setAttribute('aria-label', '複製程式碼');
						btn.textContent = '複製';
						pre.style.position = 'relative';
						pre.appendChild(btn);

						btn.addEventListener('click', async () => {
							const code = pre.querySelector('code');
							const text = code?.textContent ?? '';
							try {
								await navigator.clipboard.writeText(text);
								btn.textContent = '已複製！';
								btn.classList.add('copied');
								setTimeout(() => {
									btn.textContent = '複製';
									btn.classList.remove('copied');
								}, 2000);
							} catch {
								btn.textContent = '失敗';
								setTimeout(() => { btn.textContent = '複製'; }, 2000);
							}
						});
					});
				})();
				</script>

				<!-- 相關文章 -->
					{relatedPosts && relatedPosts.length > 0 && (
						<section class="related-posts">
							<h3 class="related-title">相關文章</h3>
							<ul class="related-grid">
								{relatedPosts.map((p) => {
									const emoji = CATEGORY_EMOJI[p.data.category ?? ''] ?? '✨';
									return (
										<li>
											<a href={`/blog/${p.id}/`} class="related-card">
												<div class="related-img-wrap">
													{p.data.heroImage ? (
														<img
															src={p.data.heroImage}
															alt={p.data.title}
															loading="lazy"
															onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
														/>
													) : null}
													<div class="related-placeholder" style={p.data.heroImage ? 'display:none' : ''}>
														<span>{emoji}</span>
													</div>
												</div>
												<div class="related-body">
													{p.data.category && <span class="badge badge-cat">{p.data.category}</span>}
													<p class="related-post-title">{p.data.title}</p>
												</div>
											</a>
										</li>
									);
								})}
							</ul>
						</section>
					)}

					<!-- Prev / Next Navigation -->
					{(prevPost || nextPost) && (
						<nav class="post-nav">
							<div class="post-nav-item prev">
								{prevPost ? (
									<a href={`/blog/${prevPost.id}/`} class="post-nav-link">
										<span class="nav-label">← 上一篇</span>
										<span class="nav-title">{prevPost.data.title}</span>
									</a>
								) : <span />}
							</div>
							<div class="post-nav-item next">
								{nextPost ? (
									<a href={`/blog/${nextPost.id}/`} class="post-nav-link">
										<span class="nav-label">下一篇 →</span>
										<span class="nav-title">{nextPost.data.title}</span>
									</a>
								) : <span />}
							</div>
						</nav>
					)}

					<!-- Back link -->
					<div class="back-row">
						<a href="/blog" class="back-link">← 回到文章列表</a>
					</div>

					<!-- Giscus 留言系統 -->
					<section class="giscus-section">
						<h3 class="giscus-heading">留言討論</h3>
						<div id="giscus-container"></div>
					</section>
				</article>

				<!-- TOC 側邊欄 -->
				<aside class="toc-sidebar" aria-label="文章目錄">
					<div class="toc-inner">
						<p class="toc-heading">目錄</p>
						<nav id="toc-nav"></nav>
					</div>
				</aside>
			</div>
		</main>

		<Footer />

		<!-- 回到頂部按鈕 -->
		<button id="back-to-top" aria-label="回到頂部" title="回到頂部">
			<svg xmlns="http://www.w3.org/2000/svg" width="20" height="20" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true"><polyline points="18 15 12 9 6 15"/></svg>
		</button>

		<!-- 閱讀進度條 JS -->
		<script>
		(function () {
			const bar = document.getElementById('reading-progress') as HTMLElement;
			if (!bar) return;
			const onScroll = () => {
				const scrollTop = window.scrollY;
				const docHeight = document.documentElement.scrollHeight - window.innerHeight;
				if (docHeight <= 0) return;
				bar.style.width = Math.min(100, (scrollTop / docHeight) * 100) + '%';
			};
			window.addEventListener('scroll', onScroll, { passive: true });
			onScroll();
		})();
		</script>

		<!-- TOC 生成 JS -->
		<script>
		(function () {
			const nav = document.getElementById('toc-nav');
			const sidebar = document.querySelector('.toc-sidebar') as HTMLElement;
			if (!nav || !sidebar) return;

			const headings = Array.from(document.querySelectorAll('.prose h2, .prose h3')) as HTMLElement[];
			if (headings.length < 2) {
				sidebar.style.display = 'none';
				return;
			}

			const ul = document.createElement('ul');
			headings.forEach(h => {
				// 確保 heading 有 id
				if (!h.id) {
					h.id = h.textContent?.trim().toLowerCase().replace(/\s+/g, '-').replace(/[^\w\u4e00-\u9fff-]/g, '') ?? '';
				}
				const li = document.createElement('li');
				const a = document.createElement('a');
				a.href = '#' + h.id;
				a.textContent = h.textContent ?? '';
				a.className = h.tagName === 'H3' ? 'toc-h3' : 'toc-h2';
				a.addEventListener('click', (e) => {
					e.preventDefault();
					document.getElementById(h.id)?.scrollIntoView({ behavior: 'smooth', block: 'start' });
					history.replaceState(null, '', '#' + h.id);
				});
				li.appendChild(a);
				ul.appendChild(li);
			});
			nav.appendChild(ul);

			// IntersectionObserver 高亮目前段落
			const links = Array.from(nav.querySelectorAll('a')) as HTMLAnchorElement[];
			const observer = new IntersectionObserver(
				(entries) => {
					entries.forEach(entry => {
						if (entry.isIntersecting) {
							links.forEach(l => l.classList.remove('active'));
							const link = nav.querySelector(`a[href="#${entry.target.id}"]`);
							link?.classList.add('active');
						}
					});
				},
				{ rootMargin: '-5% 0px -80% 0px' }
			);
			headings.forEach(h => observer.observe(h));
		})();
		</script>

		<!-- 分享按鈕 JS -->
		<script>
		(function () {
			const url = encodeURIComponent(window.location.href);
			const text = encodeURIComponent(document.title);
			const twitter = document.getElementById('share-twitter') as HTMLAnchorElement;
			const facebook = document.getElementById('share-facebook') as HTMLAnchorElement;
			const line = document.getElementById('share-line') as HTMLAnchorElement;
			if (twitter) twitter.href = `https://twitter.com/intent/tweet?url=${url}&text=${text}`;
			if (facebook) facebook.href = `https://www.facebook.com/sharer/sharer.php?u=${url}`;
			if (line) line.href = `https://social-plugins.line.me/lineit/share?url=${url}`;
		})();
		</script>

		<!-- Giscus 留言系統 JS -->
		<!-- 注意：在使用前請到 https://giscus.app 取得正確的 repo-id 和 category-id -->
		<script>
		(function () {
			const container = document.getElementById('giscus-container');
			if (!container) return;

			const isDark = document.documentElement.getAttribute('data-theme') === 'dark'
				|| (!document.documentElement.getAttribute('data-theme') && window.matchMedia('(prefers-color-scheme: dark)').matches);

			const script = document.createElement('script');
			script.src = 'https://giscus.app/client.js';
			script.setAttribute('data-repo', 'lenny1007/lennyblog');
			script.setAttribute('data-repo-id', 'REPLACE_WITH_REPO_ID');
			script.setAttribute('data-category', 'Announcements');
			script.setAttribute('data-category-id', 'REPLACE_WITH_CATEGORY_ID');
			script.setAttribute('data-mapping', 'pathname');
			script.setAttribute('data-strict', '0');
			script.setAttribute('data-reactions-enabled', '1');
			script.setAttribute('data-emit-metadata', '0');
			script.setAttribute('data-input-position', 'bottom');
			script.setAttribute('data-theme', isDark ? 'dark' : 'light');
			script.setAttribute('data-lang', 'zh-TW');
			script.setAttribute('data-loading', 'lazy');
			script.crossOrigin = 'anonymous';
			script.async = true;
			container.appendChild(script);

			// 跟隨深色模式切換
			const observer = new MutationObserver(() => {
				const nowDark = document.documentElement.getAttribute('data-theme') === 'dark'
					|| (!document.documentElement.getAttribute('data-theme') && window.matchMedia('(prefers-color-scheme: dark)').matches);
				const iframe = document.querySelector('iframe.giscus-frame') as HTMLIFrameElement;
				iframe?.contentWindow?.postMessage(
					{ giscus: { setConfig: { theme: nowDark ? 'dark' : 'light' } } },
					'https://giscus.app'
				);
			});
			observer.observe(document.documentElement, { attributes: true, attributeFilter: ['data-theme'] });
		})();
		</script>

		<!-- 回到頂部 JS -->
		<script>
		(function () {
			const btn = document.getElementById('back-to-top') as HTMLButtonElement;
			if (!btn) return;
			window.addEventListener('scroll', () => {
				btn.classList.toggle('visible', window.scrollY > 400);
			}, { passive: true });
			btn.addEventListener('click', () => {
				window.scrollTo({ top: 0, behavior: 'smooth' });
			});
		})();
		</script>
	</body>
</html>

<style>
/* ── 閱讀進度條 ─────────────────────────────────────────────────── */
#reading-progress {
	position: fixed;
	top: 0;
	left: 0;
	height: 3px;
	width: 0%;
	background: var(--color-accent);
	z-index: 200;
	transition: width 0.1s linear;
}

/* ── Layout ─────────────────────────────────────────────────────── */
main {
	max-width: 1180px;
	margin: 0 auto;
	padding: 3rem 1.5rem 5rem;
}

.post-layout {
	display: grid;
	grid-template-columns: minmax(0, 860px) 256px;
	gap: 3.5rem;
	align-items: start;
}

@media (max-width: 1100px) {
	.post-layout {
		grid-template-columns: 1fr;
	}
	.toc-sidebar {
		display: none;
	}
}

article {
	min-width: 0;
	display: flex;
	flex-direction: column;
	gap: 0;
}

/* ── Hero Image ─────────────────────────────────────────────────── */
.hero-image {
	width: 100%;
	margin-bottom: 2.5rem;
	border-radius: 16px;
	overflow: hidden;
}
.hero-image img {
	width: 100%;
	height: 400px;
	object-fit: cover;
	border-radius: 0;
	box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .hero-image img { box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5); }
}
[data-theme="dark"] .hero-image img { box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5); }

/* ── Title Section ──────────────────────────────────────────────── */
.title-section {
	text-align: center;
	margin-bottom: 3rem;
	padding-bottom: 2.5rem;
	border-bottom: 1px solid var(--color-border);
}

.meta-badges {
	display: flex;
	flex-wrap: wrap;
	justify-content: center;
	gap: 0.5rem;
	margin-bottom: 1.25rem;
}

.badge {
	display: inline-block;
	font-size: 0.8rem;
	font-weight: 700;
	padding: 0.3rem 0.9rem;
	border-radius: 9999px;
	text-decoration: none;
}
.badge-cat {
	background: var(--color-accent-light);
	color: #2563eb;
	border: 1px solid var(--color-accent-border);
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .badge-cat { color: #60a5fa; }
}
[data-theme="dark"] .badge-cat { color: #60a5fa; }
.badge-sub {
	background: #f0fdf4;
	color: #16a34a;
	border: 1px solid #bbf7d0;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .badge-sub { background: rgba(22, 163, 74, 0.1); color: #4ade80; border-color: rgba(22, 163, 74, 0.2); }
}
[data-theme="dark"] .badge-sub { background: rgba(22, 163, 74, 0.1); color: #4ade80; border-color: rgba(22, 163, 74, 0.2); }
.badge-tag {
	background: #f1f5f9;
	color: #475569;
	font-weight: 500;
	font-size: 0.78rem;
	transition: background 0.15s;
}
.badge-tag:hover {
	background: var(--color-accent-light);
	color: var(--color-accent);
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .badge-tag { background: #334155; color: #cbd5e1; }
	:root:not([data-theme="light"]) .badge-tag:hover { background: rgba(59, 130, 246, 0.15); color: #60a5fa; }
}
[data-theme="dark"] .badge-tag { background: #334155; color: #cbd5e1; }
[data-theme="dark"] .badge-tag:hover { background: rgba(59, 130, 246, 0.15); color: #60a5fa; }

.title-section h1 {
	font-size: clamp(1.8rem, 4vw, 2.6rem);
	font-weight: 800;
	letter-spacing: -0.03em;
	line-height: 1.2;
	color: var(--color-text-primary);
	margin: 0 0 1rem;
}

.date-row {
	display: flex;
	justify-content: center;
	flex-wrap: wrap;
	gap: 0.25rem;
	margin-bottom: 1rem;
	align-items: center;
}
.date {
	font-size: 0.875rem;
	color: var(--color-text-muted);
	font-weight: 500;
}
.date.updated { font-style: italic; }

.reading-time {
	font-size: 0.875rem;
	color: var(--color-text-muted);
	font-weight: 500;
}

.word-count {
	font-size: 0.875rem;
	color: var(--color-text-muted);
	font-weight: 500;
}

.tag-row {
	display: flex;
	flex-wrap: wrap;
	justify-content: center;
	gap: 0.4rem;
	margin-top: 0.5rem;
}

/* ── Prose ──────────────────────────────────────────────────────── */
.prose {
	width: 100%;
}

/* ── 分享按鈕 ───────────────────────────────────────────────────── */
.share-section {
	margin-top: 3rem;
	padding-top: 2rem;
	border-top: 1px solid var(--color-border);
	display: flex;
	align-items: center;
	flex-wrap: wrap;
	gap: 0.75rem;
}

.share-label {
	font-size: 0.875rem;
	font-weight: 700;
	color: var(--color-text-muted);
	margin-right: 0.25rem;
}

.share-buttons {
	display: flex;
	gap: 0.6rem;
	flex-wrap: wrap;
}

.share-btn {
	display: inline-flex;
	align-items: center;
	gap: 0.4rem;
	padding: 0.45rem 1rem;
	border-radius: 9999px;
	font-size: 0.82rem;
	font-weight: 600;
	text-decoration: none;
	transition: all 0.2s ease;
	border: 1px solid transparent;
}
.share-twitter {
	background: #000;
	color: #fff;
}
.share-twitter:hover {
	background: #1a1a1a;
	transform: translateY(-1px);
	text-decoration: none;
}
.share-facebook {
	background: #1877f2;
