---
import type { CollectionEntry } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';

type Props = CollectionEntry<'blog'>['data'] & {
	prevPost?: CollectionEntry<'blog'> | null;
	nextPost?: CollectionEntry<'blog'> | null;
	readingTime?: number;
};

const { title, description, pubDate, updatedDate, heroImage, category, subcategories, tags, prevPost, nextPost, readingTime } = Astro.props;
---

<html lang="zh-TW">
	<head>
		<BaseHead title={title} description={description} pubDate={pubDate} updatedDate={updatedDate} />
	</head>

	<body>
		<Header />
		<main>
			<article>
				<!-- Hero Image -->
				{heroImage && (
					<div class="hero-image">
						<img src={heroImage} alt={title} loading="eager" />
					</div>
				)}

				<!-- Title Section -->
				<div class="title-section">
					<!-- Meta badges -->
					<div class="meta-badges">
						{category && (
							<a href={`/blog/category/${encodeURIComponent(category)}`} class="badge badge-cat">{category}</a>
						)}
						{subcategories && subcategories.map((sub) => (
							<span class="badge badge-sub">{sub}</span>
						))}
					</div>

					<h1>{title}</h1>

					<div class="date-row">
						<span class="date">
							📅 <FormattedDate date={pubDate} />
						</span>
						{updatedDate && (
							<span class="date updated">
								・ 更新於 <FormattedDate date={updatedDate} />
							</span>
						)}
						{readingTime && (
							<span class="reading-time">・ 約 {readingTime} 分鐘閱讀</span>
						)}
					</div>

					{tags && tags.length > 0 && (
						<div class="tag-row">
							{tags.map((tag) => (
								<a href={`/blog/tag/${encodeURIComponent(tag)}`} class="badge badge-tag">{tag}</a>
							))}
						</div>
					)}
				</div>

				<!-- Post Body -->
				<div class="prose">
					<slot />
				</div>

				<!-- Broken image handler: hide failed images, show placeholder -->
				<script>
				document.querySelectorAll('.prose img').forEach((img) => {
					const el = img as HTMLImageElement;
					if (el.complete && el.naturalWidth === 0) {
						el.replaceWith(makePlaceholder(el.alt));
					} else {
						el.addEventListener('error', () => el.replaceWith(makePlaceholder(el.alt)));
					}
				});
				function makePlaceholder(alt: string) {
					const div = document.createElement('div');
					div.className = 'broken-img-placeholder';
					div.innerHTML = `<span class="broken-img-icon">🖼️</span><span class="broken-img-alt">${alt || '圖片無法顯示'}</span>`;
					return div;
				}
				</script>

				<!-- Prev / Next Navigation -->
				{(prevPost || nextPost) && (
					<nav class="post-nav">
						<div class="post-nav-item prev">
							{prevPost ? (
								<a href={`/blog/${prevPost.id}/`} class="post-nav-link">
									<span class="nav-label">← 上一篇</span>
									<span class="nav-title">{prevPost.data.title}</span>
								</a>
							) : <span />}
						</div>
						<div class="post-nav-item next">
							{nextPost ? (
								<a href={`/blog/${nextPost.id}/`} class="post-nav-link">
									<span class="nav-label">下一篇 →</span>
									<span class="nav-title">{nextPost.data.title}</span>
								</a>
							) : <span />}
						</div>
					</nav>
				)}

				<!-- Back link -->
				<div class="back-row">
					<a href="/blog" class="back-link">← 回到文章列表</a>
				</div>
			</article>
		</main>
		<Footer />
	</body>
</html>

<style>
main {
	max-width: 860px;
	margin: 0 auto;
	padding: 3rem 1.5rem 5rem;
}

article {
	display: flex;
	flex-direction: column;
	gap: 0;
}

/* ── Hero Image ─────────────────────────────────────────────────── */
.hero-image {
	width: 100%;
	margin-bottom: 2.5rem;
	border-radius: 16px;
	overflow: hidden;
}
.hero-image img {
	width: 100%;
	height: 400px;
	object-fit: cover;
	border-radius: 0;
	box-shadow: 0 20px 40px rgba(0, 0, 0, 0.15);
}
@media (prefers-color-scheme: dark) {
	.hero-image img { box-shadow: 0 20px 40px rgba(0, 0, 0, 0.5); }
}

/* ── Title Section ──────────────────────────────────────────────── */
.title-section {
	text-align: center;
	margin-bottom: 3rem;
	padding-bottom: 2.5rem;
	border-bottom: 1px solid var(--color-border);
}

.meta-badges {
	display: flex;
	flex-wrap: wrap;
	justify-content: center;
	gap: 0.5rem;
	margin-bottom: 1.25rem;
}

.badge {
	display: inline-block;
	font-size: 0.8rem;
	font-weight: 700;
	padding: 0.3rem 0.9rem;
	border-radius: 9999px;
	text-decoration: none;
}
.badge-cat {
	background: var(--color-accent-light);
	color: #2563eb;
	border: 1px solid var(--color-accent-border);
}
@media (prefers-color-scheme: dark) {
	.badge-cat { color: #60a5fa; }
}
.badge-sub {
	background: #f0fdf4;
	color: #16a34a;
	border: 1px solid #bbf7d0;
}
@media (prefers-color-scheme: dark) {
	.badge-sub { background: rgba(22, 163, 74, 0.1); color: #4ade80; border-color: rgba(22, 163, 74, 0.2); }
}
.badge-tag {
	background: #f1f5f9;
	color: #475569;
	font-weight: 500;
	font-size: 0.78rem;
	transition: background 0.15s;
}
.badge-tag:hover {
	background: var(--color-accent-light);
	color: var(--color-accent);
}
@media (prefers-color-scheme: dark) {
	.badge-tag { background: #334155; color: #cbd5e1; }
	.badge-tag:hover { background: rgba(59, 130, 246, 0.15); color: #60a5fa; }
}

.title-section h1 {
	font-size: clamp(1.8rem, 4vw, 2.6rem);
	font-weight: 800;
	letter-spacing: -0.03em;
	line-height: 1.2;
	color: var(--color-text-primary);
	margin: 0 0 1rem;
}

.date-row {
	display: flex;
	justify-content: center;
	flex-wrap: wrap;
	gap: 0.25rem;
	margin-bottom: 1rem;
	align-items: center;
}
.date {
	font-size: 0.875rem;
	color: var(--color-text-muted);
	font-weight: 500;
}
.date.updated { font-style: italic; }

.reading-time {
	font-size: 0.875rem;
	color: var(--color-text-muted);
	font-weight: 500;
}

.tag-row {
	display: flex;
	flex-wrap: wrap;
	justify-content: center;
	gap: 0.4rem;
	margin-top: 0.5rem;
}

/* ── Prose ──────────────────────────────────────────────────────── */
.prose {
	width: 100%;
}

/* ── Post Nav ───────────────────────────────────────────────────── */
.post-nav {
	display: grid;
	grid-template-columns: 1fr 1fr;
	gap: 1rem;
	margin-top: 4rem;
	padding-top: 2rem;
	border-top: 1px solid var(--color-border);
}

.post-nav-item.next {
	text-align: right;
}

.post-nav-link {
	display: flex;
	flex-direction: column;
	gap: 0.35rem;
	text-decoration: none;
	padding: 1rem 1.25rem;
	border: 1px solid var(--color-border);
	border-radius: 12px;
	background: var(--color-bg-card);
	transition: all 0.2s ease;
}
.post-nav-link:hover {
	border-color: #93c5fd;
	background: var(--color-accent-light);
	text-decoration: none;
	transform: translateY(-2px);
}
@media (prefers-color-scheme: dark) {
	.post-nav-link:hover { border-color: #3b82f6; }
}

.nav-label {
	font-size: 0.78rem;
	font-weight: 700;
	color: var(--color-accent);
	letter-spacing: 0.02em;
}
.nav-title {
	font-size: 0.9rem;
	font-weight: 600;
	color: var(--color-text-primary);
	line-height: 1.4;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

@media (max-width: 600px) {
	.post-nav {
		grid-template-columns: 1fr;
	}
	.post-nav-item.next {
		text-align: left;
	}
}

/* ── Back Link ──────────────────────────────────────────────────── */
.back-row {
	margin-top: 1.5rem;
}
.back-link {
	font-size: 0.9rem;
	font-weight: 600;
	color: var(--color-accent);
	text-decoration: none;
	transition: var(--transition);
}
.back-link:hover { text-decoration: underline; }
</style>
