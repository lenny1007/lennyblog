---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import { SITE_TITLE } from '../../consts';

const allPosts = await getCollection('blog');

// 統計每個標籤的文章數
const tagMap = new Map<string, number>();
for (const post of allPosts) {
	for (const tag of post.data.tags ?? []) {
		tagMap.set(tag, (tagMap.get(tag) ?? 0) + 1);
	}
}

// 依文章數降冪排列
const tags = [...tagMap.entries()]
	.sort((a, b) => b[1] - a[1])
	.map(([tag, count]) => ({ tag, count }));

const maxCount = tags[0]?.count ?? 1;
const minCount = tags[tags.length - 1]?.count ?? 1;

// 依首字母分組（方便瀏覽）
function getFontSize(count: number): string {
	const ratio = (count - minCount) / Math.max(maxCount - minCount, 1);
	const size = 0.78 + ratio * 0.9; // 0.78rem ~ 1.68rem
	return `${size.toFixed(2)}rem`;
}

function getOpacity(count: number): string {
	const ratio = (count - minCount) / Math.max(maxCount - minCount, 1);
	const op = 0.5 + ratio * 0.5;
	return op.toFixed(2);
}
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead
			title={`所有標籤 | ${SITE_TITLE}`}
			description={`共 ${tags.length} 個標籤，探索所有文章主題。`}
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>所有標籤</h1>
				<p class="subtitle">共 <strong>{tags.length}</strong> 個標籤，<strong>{allPosts.length}</strong> 篇文章</p>
			</div>

			<!-- 標籤雲 -->
			<div class="tag-cloud" role="list" aria-label="標籤列表">
				{tags.map(({ tag, count }) => (
					<a
						href={`/blog/tag/${encodeURIComponent(tag)}`}
						class="tag-item"
						role="listitem"
						style={`font-size: ${getFontSize(count)}; opacity: ${getOpacity(count)};`}
						aria-label={`${tag}，共 ${count} 篇文章`}
					>
						<span class="tag-name">#{tag}</span>
						<span class="tag-count">{count}</span>
					</a>
				))}
			</div>

			<!-- 熱門標籤列表（補充清晰度） -->
			<section class="top-tags">
				<h2 class="section-title">熱門標籤</h2>
				<ul class="top-list">
					{tags.slice(0, 10).map(({ tag, count }) => (
						<li class="top-item">
							<a href={`/blog/tag/${encodeURIComponent(tag)}`} class="top-link">
								<span class="top-tag">#{tag}</span>
								<span class="top-bar-wrap">
									<span
										class="top-bar"
										style={`width: ${Math.round((count / maxCount) * 100)}%`}
									></span>
								</span>
								<span class="top-num">{count} 篇</span>
							</a>
						</li>
					))}
				</ul>
			</section>
		</main>
		<Footer />
	</body>
</html>

<style>
main {
	max-width: 900px;
	margin: 0 auto;
	padding: 3rem 1.5rem 6rem;
}

/* ── 頁首 ────────────────────────────────────────────────────────── */
.page-header {
	margin-bottom: 3rem;
}
.page-header h1 {
	font-size: clamp(2rem, 5vw, 3rem);
	font-weight: 900;
	letter-spacing: -0.04em;
	color: var(--color-text-primary);
	margin: 0 0 0.5rem;
}
.subtitle {
	font-size: 1rem;
	color: var(--color-text-muted);
	margin: 0;
}
.subtitle strong { color: var(--color-accent); }

/* ── 標籤雲 ──────────────────────────────────────────────────────── */
.tag-cloud {
	display: flex;
	flex-wrap: wrap;
	gap: 0.6rem 0.8rem;
	align-items: center;
	margin-bottom: 4rem;
	padding: 2rem;
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 20px;
}

.tag-item {
	display: inline-flex;
	align-items: center;
	gap: 0.3rem;
	color: var(--color-accent);
	text-decoration: none;
	font-weight: 600;
	line-height: 1.3;
	transition: all 0.15s ease;
	padding: 0.1rem 0.2rem;
	border-radius: 4px;
}
.tag-item:hover {
	opacity: 1 !important;
	background: var(--color-accent-light);
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .tag-item { color: #60a5fa; }
}
[data-theme="dark"] .tag-item { color: #60a5fa; }

.tag-name { font-weight: 700; }
.tag-count {
	font-size: 0.65em;
	font-weight: 500;
	color: var(--color-text-muted);
	background: var(--color-bg-secondary);
	padding: 0.05rem 0.35rem;
	border-radius: 9999px;
}

/* ── 熱門標籤列表 ────────────────────────────────────────────────── */
.section-title {
	font-size: 1rem;
	font-weight: 800;
	letter-spacing: 0.06em;
	text-transform: uppercase;
	color: var(--color-text-muted);
	margin: 0 0 1.25rem;
}

.top-list {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0.5rem;
}

.top-item {
	display: block;
}

.top-link {
	display: grid;
	grid-template-columns: 130px 1fr 50px;
	align-items: center;
	gap: 1rem;
	padding: 0.5rem 0.75rem;
	border-radius: 10px;
	text-decoration: none;
	transition: background 0.15s ease;
}
.top-link:hover {
	background: var(--color-bg-secondary);
	text-decoration: none;
}

.top-tag {
	font-size: 0.9rem;
	font-weight: 700;
	color: var(--color-accent);
	white-space: nowrap;
	overflow: hidden;
	text-overflow: ellipsis;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .top-tag { color: #60a5fa; }
}
[data-theme="dark"] .top-tag { color: #60a5fa; }

.top-bar-wrap {
	height: 6px;
	background: var(--color-bg-secondary);
	border-radius: 9999px;
	overflow: hidden;
}
.top-bar {
	display: block;
	height: 100%;
	background: var(--color-accent);
	border-radius: 9999px;
	transition: width 0.6s ease;
}

.top-num {
	font-size: 0.8rem;
	font-weight: 600;
	color: var(--color-text-muted);
	text-align: right;
}

@media (max-width: 500px) {
	.top-link {
		grid-template-columns: 100px 1fr 40px;
		gap: 0.75rem;
	}
	.tag-cloud { padding: 1.25rem; }
}
</style>
