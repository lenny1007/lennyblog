---
import { getCollection } from 'astro:content';
import BaseHead from '../../../components/BaseHead.astro';
import Breadcrumb from '../../../components/Breadcrumb.astro';
import Footer from '../../../components/Footer.astro';
import FormattedDate from '../../../components/FormattedDate.astro';
import Header from '../../../components/Header.astro';
import { CATEGORY_EMOJI, SITE_TITLE } from '../../../consts';

export async function getStaticPaths() {
	const allPosts = await getCollection('blog');
	const categories = [...new Set(allPosts.map((p) => p.data.category).filter(Boolean))] as string[];

	return categories.map((category) => ({
		params: { category },
		props: {
			category,
			posts: allPosts
				.filter((p) => p.data.category === category)
				.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()),
		},
	}));
}

const { category, posts } = Astro.props;

const emoji = CATEGORY_EMOJI[category] ?? '📝';
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead
			title={`${category} | ${SITE_TITLE}`}
			description={`${category} 分類下共 ${posts.length} 篇文章`}
		/>
	</head>
	<body>
		<Header />
		<main>
			<Breadcrumb items={[
				{ label: '首頁', href: '/' },
				{ label: '文章', href: '/blog' },
				{ label: category },
			]} />
			<div class="page-header">
				<div class="emoji-icon">{emoji}</div>
				<h1 class="page-title">{category}</h1>
				<p class="page-subtitle">共 {posts.length} 篇文章</p>
				<a href="/blog" class="back-link">← 所有文章</a>
			</div>

			<ul class="post-grid" id="post-grid">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="post-card">
							<div class="card-img-wrap">
								{post.data.heroImage && (
									<img
										class="card-img"
										src={post.data.heroImage}
										alt={post.data.title}
										loading="lazy"
										decoding="async"
										onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
									/>
								)}
								<div class="card-img-placeholder" style={post.data.heroImage ? 'display:none' : ''}>
									<span class="card-emoji">{emoji}</span>
								</div>
							</div>
							<div class="card-body">
								<div class="card-badges">
									{(post.data.tags ?? []).slice(0, 2).map((tag) => (
										<span class="badge badge-tag">{tag}</span>
									))}
								</div>
								<h2 class="card-title">{post.data.title}</h2>
								<p class="card-desc">{post.data.description}</p>
								<div class="card-meta">
									<span class="card-date">📅 <FormattedDate date={post.data.pubDate} /></span>
								</div>
							</div>
						</a>
					</li>
				))}
			</ul>

		<!-- 分頁控制 -->
		{posts.length > 12 && (
			<div class="pagination" id="pagination" aria-label="分頁導覽"></div>
		)}
		</main>
		<Footer />
	</body>
</html>

<script>
const POSTS_PER_PAGE = 12;
const grid = document.getElementById('post-grid');
const paginationEl = document.getElementById('pagination');
if (grid && paginationEl) {
	const items = Array.from(grid.children) as HTMLElement[];
	const total = items.length;
	if (total > POSTS_PER_PAGE) {
		let currentPage = 1;
		const totalPages = Math.ceil(total / POSTS_PER_PAGE);

		function renderPage(page: number) {
			items.forEach((item, i) => {
				(item as HTMLElement).style.display = (i >= (page - 1) * POSTS_PER_PAGE && i < page * POSTS_PER_PAGE) ? '' : 'none';
			});
			renderPagination(page);
			window.scrollTo({ top: 0, behavior: 'smooth' });
		}

		function renderPagination(page: number) {
			paginationEl!.innerHTML = '';
			const prev = document.createElement('button');
			prev.className = 'page-btn';
			prev.textContent = '← 上一頁';
			prev.disabled = page === 1;
			prev.addEventListener('click', () => { currentPage--; renderPage(currentPage); });
			paginationEl!.appendChild(prev);

			const info = document.createElement('span');
			info.className = 'page-info';
			info.textContent = `第 ${page} / ${totalPages} 頁`;
			paginationEl!.appendChild(info);

			const next = document.createElement('button');
			next.className = 'page-btn';
			next.textContent = '下一頁 →';
			next.disabled = page === totalPages;
			next.addEventListener('click', () => { currentPage++; renderPage(currentPage); });
			paginationEl!.appendChild(next);
		}

		renderPage(1);
	}
}
</script>

<style>
main {
	max-width: 1200px;
	margin: 0 auto;
	padding: 4rem 1.5rem 5rem;
}

.page-header {
	text-align: center;
	margin-bottom: 3.5rem;
}
.emoji-icon {
	font-size: 3rem;
	margin-bottom: 0.75rem;
	line-height: 1;
}
.page-title {
	font-size: clamp(2rem, 5vw, 3rem);
	font-weight: 900;
	letter-spacing: -0.04em;
	color: var(--color-text-primary);
	margin-bottom: 0.5rem;
}
.page-subtitle {
	font-size: 1.1rem;
	color: var(--color-text-secondary);
	margin: 0 0 1rem;
}
.back-link {
	font-size: 0.875rem;
	font-weight: 600;
	color: var(--color-accent);
	text-decoration: none;
}
.back-link:hover { text-decoration: underline; }

.post-grid {
	list-style: none;
	padding: 0;
	margin: 0;
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
	gap: 2rem;
}

.post-card {
	display: flex;
	flex-direction: column;
	height: 100%;
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 20px;
	overflow: hidden;
	text-decoration: none;
	transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
	box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}
.post-card:hover {
	transform: translateY(-6px);
	box-shadow: 0 12px 20px -4px rgba(37, 99, 235, 0.12);
	border-color: #93c5fd;
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	.post-card { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3); }
	.post-card:hover { border-color: #3b82f6; }
}

.card-img-wrap { position: relative; width: 100%; height: 160px; flex-shrink: 0; }
.card-img { width: 100%; height: 160px; object-fit: cover; display: block; }
.card-img-placeholder {
	width: 100%; height: 160px;
	background: var(--color-bg-secondary);
	border-bottom: 1px solid var(--color-border);
	display: flex; align-items: center; justify-content: center;
}
.card-emoji { font-size: 3rem; }

.card-body {
	padding: 1.25rem 1.5rem 1.5rem;
	display: flex; flex-direction: column; flex: 1; gap: 0.5rem;
}

.card-badges { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.badge { display: inline-block; font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.65rem; border-radius: 9999px; }
.badge-tag { background: #f1f5f9; color: #475569; }
@media (prefers-color-scheme: dark) {
	.badge-tag { background: #334155; color: #cbd5e1; }
}

.card-title {
	font-size: 1.05rem; font-weight: 800; line-height: 1.4;
	color: var(--color-text-primary); margin: 0.25rem 0 0;
	display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.post-card:hover .card-title { color: var(--color-accent); }

.card-desc {
	font-size: 0.875rem; color: var(--color-text-secondary); line-height: 1.6; margin: 0; flex: 1;
	display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}

.card-meta { margin-top: auto; padding-top: 0.9rem; border-top: 1px solid var(--color-border); }
.card-date { font-size: 0.8rem; color: var(--color-text-muted); font-weight: 500; }

@media (max-width: 640px) { .post-grid { grid-template-columns: 1fr; } }

/* ── 分頁 ─────────────────────────────────────────────────────────── */
.pagination {
	display: flex;
	align-items: center;
	justify-content: center;
	gap: 1rem;
	margin-top: 3rem;
	padding-top: 2rem;
	border-top: 1px solid var(--color-border);
}
:global(.page-btn) {
	padding: 0.5rem 1.25rem;
	border-radius: 9999px;
	border: 1px solid var(--color-border);
	background: var(--color-bg-card);
	color: var(--color-text-secondary);
	font-size: 0.875rem;
	font-weight: 600;
	cursor: pointer;
	transition: all 0.2s ease;
}
:global(.page-btn:hover:not(:disabled)) {
	border-color: var(--color-accent);
	color: var(--color-accent);
	background: var(--color-accent-light);
}
:global(.page-btn:disabled) {
	opacity: 0.4;
	cursor: not-allowed;
}
:global(.page-info) {
	font-size: 0.875rem;
	font-weight: 600;
	color: var(--color-text-muted);
}
</style>
