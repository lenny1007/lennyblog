---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import Header from '../../components/Header.astro';
import Pagination from '../../components/Pagination.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../../consts';

const PAGE_SIZE = 18;

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf(),
);
const totalPages = Math.ceil(allPosts.length / PAGE_SIZE);
const posts = allPosts.slice(0, PAGE_SIZE);

const CATEGORY_EMOJI: Record<string, string> = {
	'閱讀筆記': '📖',
	'健康':     '🌿',
	'技術':     '💻',
	'AI':       '🤖',
	'學習':     '🧠',
	'創業':     '🚀',
	'理財':     '💰',
	'數位生活': '📱',
	'工作、職場': '💼',
	'人生智慧': '✨',
	'產品':     '🎯',
	'Python':   '🐍',
	'SEO':      '🔍',
};
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`文章列表 | ${SITE_TITLE}`} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />
		<main>
			<!-- Page Header -->
			<div class="page-header">
				<h1 class="page-title">所有文章</h1>
				<p class="page-subtitle">共 {allPosts.length} 篇文章，涵蓋閱讀、健康、技術等主題</p>
			</div>

			<!-- Post Grid -->
			<ul class="post-grid">
				{posts.map((post) => {
					const emoji = CATEGORY_EMOJI[post.data.category ?? ''] ?? '📝';
					return (
						<li>
							<a href={`/blog/${post.id}/`} class="post-card">
								<div class="card-img-wrap">
									{post.data.heroImage && (
										<img
											class="card-img"
											src={post.data.heroImage}
											alt={post.data.title}
											loading="lazy"
											decoding="async"
											onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
										/>
									)}
									<div class="card-img-placeholder" style={post.data.heroImage ? 'display:none' : ''}>
										<span class="card-emoji">{emoji}</span>
									</div>
								</div>
								<div class="card-body">
									<div class="card-badges">
										{post.data.category && (
											<span class="badge badge-cat">{post.data.category}</span>
										)}
										{(post.data.tags ?? []).slice(0, 2).map((tag) => (
											<span class="badge badge-tag">{tag}</span>
										))}
									</div>
									<h2 class="card-title">{post.data.title}</h2>
									<p class="card-desc">{post.data.description}</p>
									<div class="card-meta">
										<span class="card-date">
											📅 <FormattedDate date={post.data.pubDate} />
										</span>
									</div>
								</div>
							</a>
						</li>
					);
				})}
			</ul>

			<Pagination currentPage={1} totalPages={totalPages} />
		</main>
		<Footer />
	</body>
</html>

<style>
main {
	max-width: 1200px;
	margin: 0 auto;
	padding: 4rem 1.5rem 5rem;
}

.page-header {
	text-align: center;
	margin-bottom: 3.5rem;
}
.page-title {
	font-size: clamp(2rem, 5vw, 3rem);
	font-weight: 900;
	letter-spacing: -0.04em;
	color: var(--color-text-primary);
	margin-bottom: 0.75rem;
}
.page-subtitle {
	font-size: 1.1rem;
	color: var(--color-text-secondary);
	margin: 0;
}

/* ── Grid ───────────────────────────────────────────────────────── */
.post-grid {
	list-style: none;
	padding: 0;
	margin: 0;
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
	gap: 2rem;
}

/* ── Card ───────────────────────────────────────────────────────── */
.post-card {
	display: flex;
	flex-direction: column;
	height: 100%;
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 20px;
	overflow: hidden;
	text-decoration: none;
	transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
	box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}
.post-card:hover {
	transform: translateY(-6px);
	box-shadow: 0 12px 20px -4px rgba(37, 99, 235, 0.12);
	border-color: #93c5fd;
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	.post-card { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3); }
	.post-card:hover { border-color: #3b82f6; }
}

/* ── Card image ─────────────────────────────────────────────────── */
.card-img-wrap {
	position: relative;
	width: 100%;
	height: 160px;
	flex-shrink: 0;
}

.card-img {
	width: 100%;
	height: 160px;
	object-fit: cover;
	display: block;
}

.card-img-placeholder {
	width: 100%;
	height: 160px;
	background: var(--color-bg-secondary);
	border-bottom: 1px solid var(--color-border);
	display: flex;
	align-items: center;
	justify-content: center;
	transition: background 0.3s ease;
}
.post-card:hover .card-img-placeholder { background: #eff6ff; }
@media (prefers-color-scheme: dark) {
	.post-card:hover .card-img-placeholder { background: rgba(37, 99, 235, 0.08); }
}

.card-emoji { font-size: 3rem; }

.card-body {
	padding: 1.25rem 1.5rem 1.5rem;
	display: flex;
	flex-direction: column;
	flex: 1;
	gap: 0.5rem;
}

/* ── Badges ─────────────────────────────────────────────────────── */
.card-badges {
	display: flex;
	flex-wrap: wrap;
	gap: 0.4rem;
}
.badge {
	display: inline-block;
	font-size: 0.72rem;
	font-weight: 700;
	padding: 0.2rem 0.65rem;
	border-radius: 9999px;
}
.badge-cat {
	background: var(--color-accent-light);
	color: #2563eb;
	border: 1px solid var(--color-accent-border);
}
@media (prefers-color-scheme: dark) {
	.badge-cat { color: #60a5fa; }
}
.badge-tag {
	background: #f1f5f9;
	color: #475569;
}
@media (prefers-color-scheme: dark) {
	.badge-tag { background: #334155; color: #cbd5e1; }
}

/* ── Card Content ───────────────────────────────────────────────── */
.card-title {
	font-size: 1.05rem;
	font-weight: 800;
	line-height: 1.4;
	letter-spacing: -0.01em;
	color: var(--color-text-primary);
	margin: 0.25rem 0 0;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}
.post-card:hover .card-title { color: var(--color-accent); }

.card-desc {
	font-size: 0.875rem;
	color: var(--color-text-secondary);
	line-height: 1.6;
	margin: 0;
	flex: 1;
	display: -webkit-box;
	-webkit-line-clamp: 3;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.card-meta {
	margin-top: auto;
	padding-top: 0.9rem;
	border-top: 1px solid var(--color-border);
}
.card-date {
	font-size: 0.8rem;
	color: var(--color-text-muted);
	font-weight: 500;
}

@media (max-width: 640px) {
	.post-grid { grid-template-columns: 1fr; }
}
</style>
