---
import { getCollection } from 'astro:content';
import BaseHead from '../../components/BaseHead.astro';
import Header from '../../components/Header.astro';
import Footer from '../../components/Footer.astro';
import FormattedDate from '../../components/FormattedDate.astro';
import { CATEGORY_EMOJI, SITE_TITLE } from '../../consts';

const allPosts = (await getCollection('blog')).sort(
	(a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf()
);

// 依年份分組
const byYear: Record<number, typeof allPosts> = {};
allPosts.forEach(post => {
	const year = post.data.pubDate.getFullYear();
	if (!byYear[year]) byYear[year] = [];
	byYear[year].push(post);
});

const years = Object.keys(byYear).map(Number).sort((a, b) => b - a);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead
			title={`文章歸檔 | ${SITE_TITLE}`}
			description={`共 ${allPosts.length} 篇文章的完整歸檔，依年份整理。`}
			pubDate={new Date()}
		/>
	</head>
	<body>
		<Header />
		<main>
			<div class="page-header">
				<h1>文章歸檔</h1>
				<p class="subtitle">共 <strong>{allPosts.length}</strong> 篇文章</p>
			</div>

			<!-- 年份快速跳轉 -->
			<nav class="year-nav" aria-label="年份跳轉">
				{years.map(y => (
					<a href={`#year-${y}`} class="year-pill">{y} <span class="year-count">({byYear[y].length})</span></a>
				))}
			</nav>

			<!-- 時間軸 -->
			<div class="timeline">
				{years.map(year => (
					<section id={`year-${year}`} class="timeline-year">
						<!-- 年份標記 -->
						<div class="year-marker">
							<div class="year-dot"></div>
							<div class="year-label">
								<span class="year-num">{year}</span>
								<span class="year-badge">{byYear[year].length} 篇</span>
							</div>
						</div>

						<!-- 文章列表 -->
						<ul class="timeline-posts">
							{byYear[year].map(post => {
								const emoji = CATEGORY_EMOJI[post.data.category ?? ''] ?? '✨';
								const month = post.data.pubDate.toLocaleDateString('zh-TW', { month: 'short' });
								const day = post.data.pubDate.getDate();
								return (
									<li class="timeline-item">
										<div class="timeline-dot"></div>
										<div class="timeline-content">
											<div class="timeline-date">
												<span class="tl-month">{month}</span>
												<span class="tl-day">{day}</span>
											</div>
											<div class="timeline-body">
												<a href={`/blog/category/${encodeURIComponent(post.data.category ?? '')}`} class="tl-cat">
													{emoji} {post.data.category}
												</a>
												<a href={`/blog/${post.id}/`} class="tl-title">
													{post.data.title}
												</a>
											</div>
										</div>
									</li>
								);
							})}
						</ul>
					</section>
				))}
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
main {
	max-width: 800px;
	margin: 0 auto;
	padding: 3rem 1.5rem 6rem;
}

/* ── Page Header ────────────────────────────────────────────────── */
.page-header {
	margin-bottom: 2.5rem;
}
.page-header h1 {
	font-size: clamp(2rem, 5vw, 3rem);
	font-weight: 900;
	letter-spacing: -0.04em;
	color: var(--color-text-primary);
	margin: 0 0 0.5rem;
}
.subtitle {
	font-size: 1rem;
	color: var(--color-text-muted);
	margin: 0;
}
.subtitle strong { color: var(--color-accent); }

/* ── Year Nav ───────────────────────────────────────────────────── */
.year-nav {
	display: flex;
	flex-wrap: wrap;
	gap: 0.5rem;
	margin-bottom: 3rem;
}
.year-pill {
	padding: 0.4rem 1rem;
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 9999px;
	font-size: 0.875rem;
	font-weight: 700;
	color: var(--color-text-secondary);
	text-decoration: none;
	transition: all 0.2s ease;
}
.year-pill:hover {
	border-color: var(--color-accent);
	color: var(--color-accent);
	background: var(--color-accent-light);
	text-decoration: none;
}
.year-count {
	font-weight: 400;
	color: var(--color-text-muted);
}

/* ── Timeline ───────────────────────────────────────────────────── */
.timeline {
	position: relative;
}

/* 左側垂直線 */
.timeline::before {
	content: '';
	position: absolute;
	left: 2.25rem;
	top: 0;
	bottom: 0;
	width: 2px;
	background: linear-gradient(to bottom, var(--color-accent) 0%, var(--color-border) 100%);
}

/* ── 年份標記 ───────────────────────────────────────────────────── */
.timeline-year {
	margin-bottom: 2.5rem;
	position: relative;
}

.year-marker {
	display: flex;
	align-items: center;
	gap: 1rem;
	margin-bottom: 1rem;
	position: relative;
}

.year-dot {
	width: 1.25rem;
	height: 1.25rem;
	border-radius: 50%;
	background: var(--color-accent);
	border: 3px solid var(--color-bg);
	box-shadow: 0 0 0 2px var(--color-accent);
	flex-shrink: 0;
	margin-left: 1.625rem; /* (2.25rem - 1.25rem/2) to center on the line */
	z-index: 1;
}

.year-label {
	display: flex;
	align-items: center;
	gap: 0.6rem;
	margin-left: 0.5rem;
}

.year-num {
	font-size: 1.4rem;
	font-weight: 900;
	color: var(--color-text-primary);
	letter-spacing: -0.03em;
}

.year-badge {
	font-size: 0.75rem;
	font-weight: 700;
	color: var(--color-text-muted);
	background: var(--color-bg-secondary);
	border: 1px solid var(--color-border);
	padding: 0.15rem 0.6rem;
	border-radius: 9999px;
}

/* ── 時間軸文章列表 ──────────────────────────────────────────────── */
.timeline-posts {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-direction: column;
	gap: 0;
}

.timeline-item {
	display: flex;
	align-items: flex-start;
	gap: 0;
	position: relative;
	padding: 0.5rem 0;
}

.timeline-dot {
	width: 0.6rem;
	height: 0.6rem;
	border-radius: 50%;
	background: var(--color-border);
	border: 2px solid var(--color-bg);
	flex-shrink: 0;
	margin-top: 0.45rem;
	margin-left: 1.975rem; /* center on the 2px line: 2.25rem - 0.3rem offset */
	transition: background 0.15s;
	z-index: 1;
}

.timeline-item:hover .timeline-dot {
	background: var(--color-accent);
}

.timeline-content {
	display: flex;
	align-items: flex-start;
	gap: 1rem;
	margin-left: 1.5rem;
	flex: 1;
	padding: 0.5rem 0.75rem;
	border-radius: 10px;
	transition: background 0.15s ease;
}

.timeline-item:hover .timeline-content {
	background: var(--color-bg-secondary);
}

.timeline-date {
	flex-shrink: 0;
	display: flex;
	flex-direction: column;
	align-items: center;
	width: 2.25rem;
	padding-top: 0.1rem;
}

.tl-month {
	font-size: 0.65rem;
	font-weight: 700;
	text-transform: uppercase;
	color: var(--color-text-muted);
	letter-spacing: 0.05em;
}

.tl-day {
	font-size: 1.1rem;
	font-weight: 800;
	color: var(--color-text-muted);
	line-height: 1.2;
}

.timeline-body {
	flex: 1;
	min-width: 0;
	display: flex;
	flex-direction: column;
	gap: 0.2rem;
}

.tl-cat {
	font-size: 0.72rem;
	font-weight: 700;
	color: var(--color-accent);
	text-decoration: none;
	display: inline-flex;
	align-items: center;
	gap: 0.2rem;
	transition: opacity 0.15s;
}
.tl-cat:hover {
	text-decoration: underline;
	opacity: 0.8;
}
@media (prefers-color-scheme: dark) {
	.tl-cat { color: #60a5fa; }
}
[data-theme="dark"] .tl-cat { color: #60a5fa; }

.tl-title {
	font-size: 0.95rem;
	font-weight: 600;
	color: var(--color-text-primary);
	text-decoration: none;
	line-height: 1.4;
	transition: color 0.15s;
	display: block;
}
.tl-title:hover {
	color: var(--color-accent);
	text-decoration: none;
}

/* ── 手機版 ─────────────────────────────────────────────────────── */
@media (max-width: 640px) {
	.timeline::before {
		left: 1.25rem;
	}
	.year-dot {
		margin-left: 0.625rem;
	}
	.timeline-dot {
		margin-left: 0.975rem;
	}
	.timeline-content {
		gap: 0.75rem;
	}
	.timeline-date {
		width: 2rem;
	}
	.tl-day { font-size: 1rem; }
}
</style>
