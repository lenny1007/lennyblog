---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
import { SITE_TITLE } from '../consts';
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={`搜尋 | ${SITE_TITLE}`} description="搜尋所有文章" />
	</head>
	<body>
		<Header />
		<main>
			<div class="search-header">
				<h1 class="page-title">搜尋文章</h1>
				<div class="search-wrap">
					<span class="search-icon" aria-hidden="true">🔍</span>
					<input
						id="search-input"
						type="search"
						placeholder="輸入關鍵字搜尋標題、描述、標籤…"
						autofocus
						autocomplete="off"
					/>
				</div>
				<p id="search-status" class="search-status" aria-live="polite"></p>
			</div>

			<ul id="results" class="post-grid" role="list"></ul>
		</main>
		<Footer />
	</body>
</html>

<script>
import Fuse from 'fuse.js';

interface PostEntry {
	id: string;
	title: string;
	description: string;
	category: string;
	tags: string[];
	pubDate: string;
	url: string;
}

const input = document.getElementById('search-input') as HTMLInputElement;
const resultsList = document.getElementById('results') as HTMLUListElement;
const statusEl = document.getElementById('search-status') as HTMLParagraphElement;

let fuse: Fuse<PostEntry> | null = null;
let allPosts: PostEntry[] = [];

function esc(str: string) {
	return str.replace(/&/g, '&amp;').replace(/</g, '&lt;').replace(/>/g, '&gt;').replace(/"/g, '&quot;');
}

// Load search index
fetch('/search-index.json')
	.then((r) => {
		if (!r.ok) throw new Error(`HTTP ${r.status}`);
		return r.json();
	})
	.then((data: PostEntry[]) => {
		allPosts = data;
		fuse = new Fuse(data, {
			keys: [
				{ name: 'title', weight: 3 },
				{ name: 'description', weight: 2 },
				{ name: 'category', weight: 1.5 },
				{ name: 'tags', weight: 1 },
			],
			threshold: 0.35,
			includeScore: true,
			minMatchCharLength: 2,
		});

		// Pre-populate with query string if present
		const q = new URLSearchParams(window.location.search).get('q') ?? '';
		if (q) {
			input.value = q;
			doSearch(q);
		}
	})
	.catch(() => {
		statusEl.textContent = '搜尋索引載入失敗，請重新整理頁面。';
	});

function renderPost(post: PostEntry) {
	return `
		<li>
			<a href="${esc(post.url)}" class="post-card">
				<div class="card-body">
					<div class="card-badges">
						${post.category ? `<span class="badge badge-cat">${esc(post.category)}</span>` : ''}
						${post.tags.slice(0, 2).map((t) => `<span class="badge badge-tag">${esc(t)}</span>`).join('')}
					</div>
					<h2 class="card-title">${esc(post.title)}</h2>
					<p class="card-desc">${esc(post.description)}</p>
					<div class="card-meta">
						<span class="card-date">📅 ${esc(post.pubDate)}</span>
					</div>
				</div>
			</a>
		</li>`;
}

function doSearch(query: string) {
	if (!fuse) return;

	const trimmed = query.trim();
	if (!trimmed) {
		resultsList.innerHTML = '';
		statusEl.textContent = '';
		return;
	}

	const results = fuse.search(trimmed);
	if (results.length === 0) {
		resultsList.innerHTML = '';
		statusEl.textContent = `找不到「${trimmed}」的相關文章`;
		return;
	}

	statusEl.textContent = `找到 ${results.length} 篇相關文章`;
	resultsList.innerHTML = results.map((r) => renderPost(r.item)).join('');
}

input.addEventListener('input', (e) => {
	const q = (e.target as HTMLInputElement).value;
	// Update URL without reload for shareability
	const url = new URL(window.location.href);
	if (q.trim()) {
		url.searchParams.set('q', q.trim());
	} else {
		url.searchParams.delete('q');
	}
	window.history.replaceState({}, '', url);
	doSearch(q);
});
</script>

<style>
main {
	max-width: 1200px;
	margin: 0 auto;
	padding: 4rem 1.5rem 5rem;
}

.search-header {
	text-align: center;
	margin-bottom: 3rem;
}

.page-title {
	font-size: clamp(2rem, 5vw, 3rem);
	font-weight: 900;
	letter-spacing: -0.04em;
	color: var(--color-text-primary);
	margin-bottom: 1.5rem;
}

.search-wrap {
	position: relative;
	max-width: 640px;
	margin: 0 auto;
}

.search-icon {
	position: absolute;
	left: 1.25rem;
	top: 50%;
	transform: translateY(-50%);
	font-size: 1.1rem;
	pointer-events: none;
}

#search-input {
	width: 100%;
	padding: 1rem 1.25rem 1rem 3rem;
	font-size: 1.05rem;
	border: 2px solid var(--color-border);
	border-radius: 9999px;
	background: var(--color-bg-card);
	color: var(--color-text-primary);
	outline: none;
	transition: border-color 0.2s ease, box-shadow 0.2s ease;
	box-sizing: border-box;
}
#search-input:focus {
	border-color: var(--color-accent);
	box-shadow: 0 0 0 3px rgba(37, 99, 235, 0.12);
}
#search-input::placeholder { color: var(--color-text-muted); }

.search-status {
	margin-top: 1rem;
	font-size: 0.9rem;
	color: var(--color-text-muted);
	min-height: 1.4em;
}

/* Post Grid */
.post-grid {
	list-style: none;
	padding: 0;
	margin: 0;
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(340px, 1fr));
	gap: 2rem;
}

.post-card {
	display: flex;
	flex-direction: column;
	height: 100%;
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 20px;
	overflow: hidden;
	text-decoration: none;
	transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
	box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}
.post-card:hover {
	transform: translateY(-6px);
	box-shadow: 0 12px 20px -4px rgba(37, 99, 235, 0.12);
	border-color: #93c5fd;
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	.post-card { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3); }
	.post-card:hover { border-color: #3b82f6; }
}

.card-body {
	padding: 1.5rem;
	display: flex;
	flex-direction: column;
	flex: 1;
	gap: 0.5rem;
}

.card-badges { display: flex; flex-wrap: wrap; gap: 0.4rem; }
.badge { display: inline-block; font-size: 0.72rem; font-weight: 700; padding: 0.2rem 0.65rem; border-radius: 9999px; }
.badge-cat {
	background: var(--color-accent-light);
	color: #2563eb;
	border: 1px solid var(--color-accent-border);
}
@media (prefers-color-scheme: dark) {
	.badge-cat { color: #60a5fa; }
}
.badge-tag { background: #f1f5f9; color: #475569; }
@media (prefers-color-scheme: dark) {
	.badge-tag { background: #334155; color: #cbd5e1; }
}

.card-title {
	font-size: 1.05rem; font-weight: 800; line-height: 1.4;
	color: var(--color-text-primary); margin: 0.25rem 0 0;
	display: -webkit-box; -webkit-line-clamp: 2; -webkit-box-orient: vertical; overflow: hidden;
}
.post-card:hover .card-title { color: var(--color-accent); }

.card-desc {
	font-size: 0.875rem; color: var(--color-text-secondary);
	line-height: 1.6; margin: 0; flex: 1;
	display: -webkit-box; -webkit-line-clamp: 3; -webkit-box-orient: vertical; overflow: hidden;
}

.card-meta { margin-top: auto; padding-top: 0.9rem; border-top: 1px solid var(--color-border); }
.card-date { font-size: 0.8rem; color: var(--color-text-muted); font-weight: 500; }

@media (max-width: 640px) {
	.post-grid { grid-template-columns: 1fr; }
}
</style>
