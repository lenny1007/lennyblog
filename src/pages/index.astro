---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { CATEGORY_EMOJI, SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const allPosts = await getCollection('blog');
const posts = allPosts
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 9);

// 精選文章：frontmatter 中 featured: true 的文章（最多 6 篇）
const featuredPosts = allPosts
	.filter((p) => p.data.featured === true)
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 6);

// 統計每個分類的文章數
const categoryCounts: Record<string, number> = {};
allPosts.forEach(p => {
	if (p.data.category) {
		categoryCounts[p.data.category] = (categoryCounts[p.data.category] ?? 0) + 1;
	}
});
const categories = Object.entries(categoryCounts)
	.sort((a, b) => b[1] - a[1]);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="hero">
			<div class="hero-glow"></div>
			<div class="hero-inner">
				<div class="hero-chips">
					<span class="hero-chip">📚 閱讀 × 輸出</span>
					<span class="hero-chip">✍️ 每週電子報</span>
				</div>
				<h1>
					閱讀，是<br />
					<span class="gradient-text">最好的投資</span>
				</h1>
				<p class="hero-desc">
					透過輸出轉化自己的閱讀，也希望能讓偶然逛到這裡的你能更喜歡閱讀。
				</p>
				<div class="hero-actions">
					<a href="/blog" class="btn-primary">瀏覽所有文章</a>
					<a href="/about" class="btn-secondary">關於作者</a>
				</div>
			</div>
		</section>

		<!-- 分類區塊 -->
		<section class="categories-section">
			<div class="categories-inner">
				<h2 class="section-title">探索主題</h2>
				<ul class="categories-grid">
					{categories.map(([cat, count]) => {
						const emoji = CATEGORY_EMOJI[cat] ?? '✨';
						return (
							<li>
								<a href={`/blog/category/${encodeURIComponent(cat)}`} class="cat-card">
									<span class="cat-emoji">{emoji}</span>
									<span class="cat-name">{cat}</span>
									<span class="cat-count">{count} 篇</span>
								</a>
							</li>
						);
					})}
				</ul>
			</div>
		</section>

		<!-- 精選文章 -->
		{featuredPosts.length > 0 && (
			<section class="featured-section">
				<div class="featured-inner">
					<div class="section-header">
						<h2 class="section-title">⭐ 精選文章</h2>
						<a href="/blog" class="view-all">查看全部 →</a>
					</div>
					<ul class="featured-grid">
						{featuredPosts.map((post) => {
							const emoji = CATEGORY_EMOJI[post.data.category ?? ''] ?? '✨';
							return (
								<li>
									<a href={`/blog/${post.id}/`} class="featured-card">
										<div class="featured-img-wrap">
											{post.data.heroImage && (
												<img
													class="featured-img"
													src={post.data.heroImage}
													alt={post.data.title}
													loading="lazy"
													decoding="async"
													onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
												/>
											)}
											<div class="featured-img-placeholder" style={post.data.heroImage ? 'display:none' : ''}>
												<span>{emoji}</span>
											</div>
										</div>
										<div class="featured-body">
											{post.data.category && (
												<span class="badge badge-cat">{post.data.category}</span>
											)}
											<h3 class="featured-title">{post.data.title}</h3>
											<p class="featured-desc">{post.data.description}</p>
										</div>
									</a>
								</li>
							);
						})}
					</ul>
				</div>
			</section>
		)}

		<!-- Recent Posts -->
		<main>
			<div class="section-header">
				<h2 class="section-title">最新文章</h2>
				<a href="/blog" class="view-all">查看全部 →</a>
			</div>

			<ul class="post-grid">
				{posts.map((post) => {
					const emoji = CATEGORY_EMOJI[post.data.category ?? ''] ?? '✨';
					return (
						<li>
							<a href={`/blog/${post.id}/`} class="post-card">
								<div class="card-img-wrap">
									{post.data.heroImage && (
										<img
											class="card-img"
											src={post.data.heroImage}
											alt={post.data.title}
											loading="lazy"
											decoding="async"
											onerror={`this.style.display='none';this.nextElementSibling.style.display='flex'`}
										/>
									)}
									<div class="card-img-placeholder" style={post.data.heroImage ? 'display:none' : ''}>
										<span class="card-emoji">{emoji}</span>
									</div>
								</div>
								<div class="card-body">
									{post.data.category && (
										<span class="badge badge-cat">{post.data.category}</span>
									)}
									<h3 class="card-title">{post.data.title}</h3>
									<p class="card-desc">{post.data.description}</p>
									<div class="card-meta">
										<FormattedDate date={post.data.pubDate} />
									</div>
								</div>
							</a>
						</li>
					);
				})}
			</ul>
		</main>

		<!-- Newsletter 訂閱 -->
		<section class="nl-section">
			<div class="nl-blob nl-blob-1"></div>
			<div class="nl-blob nl-blob-2"></div>
			<div class="nl-inner">
				<!-- 左側：文案 -->
				<div class="nl-copy">
					<span class="nl-badge">📬 每週電子報</span>
					<h2 class="nl-title">
						把閱讀變成<br />
						<span class="nl-accent">你的競爭力</span>
					</h2>
					<p class="nl-desc">精選閱讀心得與人生思考，直接送進你的信箱。<br />不追流量，只寫有誠意的內容。</p>
					<ul class="nl-perks">
						<li><span class="nl-perk-icon">📖</span>閱讀精華 &amp; 書單推薦</li>
						<li><span class="nl-perk-icon">🧠</span>值得思考的觀點與框架</li>
						<li><span class="nl-perk-icon">✨</span>不定期，但每封都用心寫</li>
					</ul>
				</div>
				<!-- 右側：表單卡片 -->
				<div class="nl-card">
					<p class="nl-card-lead">加入讀者行列</p>
					<form
						class="nl-form"
						action="https://buttondown.com/api/emails/embed-subscribe/lenny0929"
						method="post"
						target="popupwindow"
						onsubmit="window.open('https://buttondown.com/lenny0929', 'popupwindow'); setTimeout(function(){ window.location.href='/thanks'; }, 1500);"
					>
						<input type="hidden" name="embed" value="1" />
						<input
							type="email"
							name="email"
							class="nl-input"
							placeholder="your@email.com"
							required
						/>
						<button type="submit" class="nl-btn">免費訂閱 →</button>
						<p class="nl-note">🔒 零垃圾信，隨時取消，完全免費</p>
					</form>
				</div>
			</div>
		</section>

		<Footer />
	</body>
</html>

<style>
/* ── Hero ───────────────────────────────────────────────────────── */
.hero {
	position: relative;
	overflow: hidden;
	background: #f8fafc;
	padding: 7rem 1.5rem 6rem;
	text-align: center;
	border-bottom: 1px solid #e2e8f0;
}
/* dot-grid texture */
.hero::before {
	content: '';
	position: absolute;
	inset: 0;
	background-image: radial-gradient(circle, #d1d5db 1px, transparent 1px);
	background-size: 28px 28px;
	opacity: 0.6;
	pointer-events: none;
}
.hero-glow {
	position: absolute;
	top: -140px;
	left: 50%;
	transform: translateX(-50%);
	width: 700px;
	height: 500px;
	background: radial-gradient(ellipse, rgba(99,102,241,0.12) 0%, transparent 65%);
	pointer-events: none;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .hero {
		background: #0a0f1e;
		border-bottom-color: #1e293b;
	}
	:root:not([data-theme="light"]) .hero::before {
		background-image: radial-gradient(circle, #1e293b 1px, transparent 1px);
		opacity: 1;
	}
	:root:not([data-theme="light"]) .hero-glow {
		background: radial-gradient(ellipse, rgba(99,102,241,0.22) 0%, transparent 65%);
	}
}
[data-theme="dark"] .hero { background: #0a0f1e; border-bottom-color: #1e293b; }
[data-theme="dark"] .hero::before {
	background-image: radial-gradient(circle, #1e293b 1px, transparent 1px);
	opacity: 1;
}
[data-theme="dark"] .hero-glow {
	background: radial-gradient(ellipse, rgba(99,102,241,0.22) 0%, transparent 65%);
}

.hero-inner {
	position: relative;
	max-width: 700px;
	margin: 0 auto;
}

/* chips */
.hero-chips {
	display: flex;
	justify-content: center;
	gap: 0.6rem;
	margin-bottom: 1.75rem;
	flex-wrap: wrap;
}
.hero-chip {
	display: inline-flex;
	align-items: center;
	gap: 0.3rem;
	font-size: 0.78rem;
	font-weight: 700;
	color: #6366f1;
	background: rgba(99,102,241,0.08);
	border: 1px solid rgba(99,102,241,0.22);
	padding: 0.3rem 0.85rem;
	border-radius: 9999px;
	letter-spacing: 0.02em;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .hero-chip {
		color: #a5b4fc;
		background: rgba(99,102,241,0.15);
		border-color: rgba(99,102,241,0.35);
	}
}
[data-theme="dark"] .hero-chip {
	color: #a5b4fc;
	background: rgba(99,102,241,0.15);
	border-color: rgba(99,102,241,0.35);
}

.hero h1 {
	font-size: clamp(2.8rem, 7vw, 4.5rem);
	font-weight: 900;
	letter-spacing: -0.05em;
	line-height: 1.05;
	margin: 0 0 1.5rem;
	color: #0f172a;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .hero h1 { color: #f1f5f9; }
}
[data-theme="dark"] .hero h1 { color: #f1f5f9; }

.gradient-text {
	background: linear-gradient(135deg, #6366f1 0%, #3b82f6 55%, #06b6d4 100%);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-clip: text;
}

.hero-desc {
	font-size: 1.15rem;
	color: #64748b;
	max-width: 520px;
	margin: 0 auto 2.75rem;
	line-height: 1.78;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .hero-desc { color: #94a3b8; }
}
[data-theme="dark"] .hero-desc { color: #94a3b8; }

.hero-actions {
	display: flex;
	justify-content: center;
	gap: 0.875rem;
	flex-wrap: wrap;
}

.btn-primary {
	background: linear-gradient(135deg, #6366f1, #3b82f6);
	color: #fff;
	padding: 0.825rem 2.1rem;
	border-radius: 0.875rem;
	font-weight: 700;
	font-size: 1rem;
	text-decoration: none;
	transition: all 0.2s ease;
	box-shadow: 0 4px 14px rgba(99,102,241,0.38);
}
.btn-primary:hover {
	background: linear-gradient(135deg, #4f46e5, #2563eb);
	transform: translateY(-2px);
	box-shadow: 0 8px 22px rgba(99,102,241,0.48);
	text-decoration: none;
}

.btn-secondary {
	background: transparent;
	color: #475569;
	padding: 0.825rem 2.1rem;
	border-radius: 0.875rem;
	border: 1.5px solid #d1d5db;
	font-weight: 600;
	font-size: 1rem;
	text-decoration: none;
	transition: all 0.2s ease;
}
.btn-secondary:hover {
	background: #f1f5f9;
	border-color: #9ca3af;
	text-decoration: none;
	transform: translateY(-2px);
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .btn-secondary { color: #94a3b8; border-color: #334155; }
	:root:not([data-theme="light"]) .btn-secondary:hover { background: #1e293b; color: #f1f5f9; border-color: #475569; }
}
[data-theme="dark"] .btn-secondary { color: #94a3b8; border-color: #334155; }
[data-theme="dark"] .btn-secondary:hover { background: #1e293b; color: #f1f5f9; border-color: #475569; }

/* ── 分類區塊 ───────────────────────────────────────────────────── */
.categories-section {
	background: var(--color-bg-secondary);
	border-bottom: 1px solid var(--color-border);
	padding: 4rem 1.5rem;
}

.categories-inner {
	max-width: 1200px;
	margin: 0 auto;
}

.categories-inner .section-title {
	font-size: 1.5rem;
	font-weight: 800;
	letter-spacing: -0.03em;
	margin: 0 0 1.75rem;
}

/* Pill-style tag layout */
.categories-grid {
	list-style: none;
	padding: 0;
	margin: 0;
	display: flex;
	flex-wrap: wrap;
	gap: 0.75rem;
}

.cat-card {
	display: inline-flex;
	align-items: center;
	gap: 0.5rem;
	padding: 0.6rem 1.2rem;
	background: var(--color-bg-card);
	border: 1.5px solid var(--color-border);
	border-radius: 9999px;
	text-decoration: none;
	transition: all 0.2s ease;
	white-space: nowrap;
}
.cat-card:hover {
	border-color: #6366f1;
	background: rgba(99,102,241,0.06);
	transform: translateY(-2px);
	box-shadow: 0 4px 14px rgba(99,102,241,0.14);
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .cat-card:hover {
		background: rgba(99,102,241,0.12);
		border-color: #818cf8;
	}
}
[data-theme="dark"] .cat-card:hover {
	background: rgba(99,102,241,0.12);
	border-color: #818cf8;
}

.cat-emoji { font-size: 1.05rem; line-height: 1; }

.cat-name {
	font-size: 0.88rem;
	font-weight: 700;
	color: var(--color-text-primary);
}

.cat-count {
	font-size: 0.72rem;
	font-weight: 600;
	color: var(--color-text-muted);
	background: var(--color-bg-secondary);
	padding: 0.1rem 0.5rem;
	border-radius: 9999px;
}

/* ── 精選文章 ───────────────────────────────────────────────────── */
.featured-section {
	background: var(--color-bg);
	padding: 4.5rem 1.5rem 0;
}
.featured-inner {
	max-width: 1200px;
	margin: 0 auto;
}
.featured-inner .section-header {
	margin-bottom: 1.75rem;
}
.featured-grid {
	list-style: none;
	padding: 0;
	margin: 0 0 3rem;
	display: grid;
	grid-template-columns: repeat(2, 1fr);
	gap: 1rem;
}
@media (max-width: 620px) {
	.featured-grid { grid-template-columns: 1fr; }
}
/* First card spans full width as hero featured */
.featured-grid li:first-child {
	grid-column: 1 / -1;
}
.featured-card {
	display: flex;
	flex-direction: row;
	align-items: center;
	gap: 1rem;
	background: var(--color-bg-card);
	border: 1.5px solid var(--color-border);
	border-radius: 1rem;
	overflow: hidden;
	text-decoration: none;
	transition: all 0.22s ease;
	padding: 0.9rem 1.1rem 0.9rem 0;
}
.featured-card:hover {
	border-color: #6366f1;
	transform: translateY(-3px);
	box-shadow: 0 8px 24px rgba(99,102,241,0.14);
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .featured-card:hover {
		border-color: #818cf8;
		box-shadow: 0 8px 24px rgba(99,102,241,0.2);
	}
}
[data-theme="dark"] .featured-card:hover {
	border-color: #818cf8;
	box-shadow: 0 8px 24px rgba(99,102,241,0.2);
}

.featured-img-wrap {
	flex-shrink: 0;
	width: 88px;
	height: 88px;
	border-radius: 0.75rem;
	overflow: hidden;
	margin-left: 0.9rem;
}
.featured-img {
	width: 88px;
	height: 88px;
	object-fit: cover;
	display: block;
}
.featured-img-placeholder {
	width: 88px;
	height: 88px;
	background: linear-gradient(135deg, rgba(99,102,241,0.12), rgba(59,130,246,0.12));
	border-radius: 0.75rem;
	display: flex;
	align-items: center;
	justify-content: center;
	font-size: 1.9rem;
}

/* Hero featured card (first child): larger image */
.featured-grid li:first-child .featured-img-wrap {
	width: 140px;
	height: 108px;
}
.featured-grid li:first-child .featured-img {
	width: 140px;
	height: 108px;
}
.featured-grid li:first-child .featured-img-placeholder {
	width: 140px;
	height: 108px;
	font-size: 2.75rem;
}
.featured-grid li:first-child .featured-title {
	font-size: 1rem;
	-webkit-line-clamp: 3;
}
.featured-grid li:first-child .featured-desc {
	-webkit-line-clamp: 3;
}

.featured-body {
	flex: 1;
	display: flex;
	flex-direction: column;
	gap: 0.35rem;
	min-width: 0;
}
.featured-title {
	font-size: 0.88rem;
	font-weight: 700;
	color: var(--color-text-primary);
	line-height: 1.45;
	margin: 0;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}
.featured-card:hover .featured-title { color: #6366f1; }
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .featured-card:hover .featured-title { color: #a5b4fc; }
}
[data-theme="dark"] .featured-card:hover .featured-title { color: #a5b4fc; }

.featured-desc {
	font-size: 0.77rem;
	color: var(--color-text-muted);
	line-height: 1.55;
	margin: 0;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

/* ── Main / Posts ───────────────────────────────────────────────── */
main {
	max-width: 1200px;
	margin: 0 auto;
	padding: 4.5rem 1.5rem 5.5rem;
}

.section-header {
	display: flex;
	align-items: baseline;
	justify-content: space-between;
	margin-bottom: 2rem;
}
.section-title {
	font-size: 1.7rem;
	font-weight: 800;
	letter-spacing: -0.03em;
	margin: 0;
}
.view-all {
	font-size: 0.875rem;
	font-weight: 600;
	color: #6366f1;
	text-decoration: none;
	transition: color 0.15s;
}
.view-all:hover { color: #4f46e5; text-decoration: underline; }
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .view-all { color: #a5b4fc; }
	:root:not([data-theme="light"]) .view-all:hover { color: #c7d2fe; }
}
[data-theme="dark"] .view-all { color: #a5b4fc; }
[data-theme="dark"] .view-all:hover { color: #c7d2fe; }

/* ── Post Grid ──────────────────────────────────────────────────── */
.post-grid {
	list-style: none;
	padding: 0;
	margin: 0;
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(300px, 1fr));
	gap: 1.75rem;
}

.post-card {
	display: flex;
	flex-direction: column;
	height: 100%;
	background: var(--color-bg-card);
	border: 1.5px solid var(--color-border);
	border-radius: 1.1rem;
	overflow: hidden;
	text-decoration: none;
	transition: all 0.25s cubic-bezier(0.25, 0.8, 0.25, 1);
	box-shadow: 0 2px 8px rgba(0,0,0,0.04);
}
.post-card:hover {
	transform: translateY(-5px);
	box-shadow: 0 12px 28px rgba(99,102,241,0.12);
	border-color: #6366f1;
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	:root:not([data-theme="light"]) .post-card { box-shadow: 0 2px 8px rgba(0,0,0,0.25); }
	:root:not([data-theme="light"]) .post-card:hover {
		border-color: #818cf8;
		box-shadow: 0 12px 28px rgba(99,102,241,0.18);
	}
}
[data-theme="dark"] .post-card { box-shadow: 0 2px 8px rgba(0,0,0,0.25); }
[data-theme="dark"] .post-card:hover {
	border-color: #818cf8;
	box-shadow: 0 12px 28px rgba(99,102,241,0.18);
}

.card-img-wrap {
	position: relative;
	width: 100%;
	height: 168px;
	flex-shrink: 0;
}
.card-img {
	width: 100%;
	height: 168px;
	object-fit: cover;
	display: block;
}
.card-img-placeholder {
	width: 100%;
	height: 168px;
