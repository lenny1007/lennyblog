---
import { getCollection } from 'astro:content';
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import FormattedDate from '../components/FormattedDate.astro';
import Header from '../components/Header.astro';
import { SITE_DESCRIPTION, SITE_TITLE } from '../consts';

const posts = (await getCollection('blog'))
	.sort((a, b) => b.data.pubDate.valueOf() - a.data.pubDate.valueOf())
	.slice(0, 9);
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title={SITE_TITLE} description={SITE_DESCRIPTION} />
	</head>
	<body>
		<Header />

		<!-- Hero -->
		<section class="hero">
			<div class="hero-inner">
				<h1>
					閱讀，是<br />
					<span class="gradient-text">最好的投資</span>
				</h1>
				<p class="hero-desc">
					透過輸出轉化自己的閱讀，也希望能讓偶然逛到這裡的你能更喜歡閱讀。
				</p>
				<div class="hero-actions">
					<a href="/blog" class="btn-primary">瀏覽所有文章</a>
					<a href="/about" class="btn-secondary">關於作者</a>
				</div>
			</div>
		</section>

		<!-- Recent Posts -->
		<main>
			<div class="section-header">
				<h2 class="section-title">最新文章</h2>
				<a href="/blog" class="view-all">查看全部 →</a>
			</div>

			<ul class="post-grid">
				{posts.map((post) => (
					<li>
						<a href={`/blog/${post.id}/`} class="post-card">
							{post.data.heroImage ? (
								<img
									class="card-img"
									src={post.data.heroImage}
									alt={post.data.title}
									loading="lazy"
									decoding="async"
								/>
							) : (
								<div class="card-img-placeholder">
									<span class="card-emoji">
										{post.data.category === '閱讀筆記' ? '📖' :
										 post.data.category === '健康' ? '🌿' :
										 post.data.category === '技術' ? '💻' :
										 post.data.category === 'AI' ? '🤖' :
										 post.data.category === '學習' ? '🧠' :
										 post.data.category === '創業' ? '🚀' :
										 post.data.category === '理財' ? '💰' :
										 post.data.category === '數位生活' ? '📱' : '✨'}
									</span>
								</div>
							)}
							<div class="card-body">
								{post.data.category && (
									<span class="badge badge-cat">{post.data.category}</span>
								)}
								<h3 class="card-title">{post.data.title}</h3>
								<p class="card-desc">{post.data.description}</p>
								<div class="card-meta">
									<FormattedDate date={post.data.pubDate} />
								</div>
							</div>
						</a>
					</li>
				))}
			</ul>
		</main>

		<Footer />
	</body>
</html>

<style>
/* ── Hero ───────────────────────────────────────────────────────── */
.hero {
	background: linear-gradient(180deg, #e0f2fe 0%, #f8fafc 100%);
	border-bottom: 1px solid #e2e8f0;
	padding: 7rem 1.5rem 5rem;
	text-align: center;
}
@media (prefers-color-scheme: dark) {
	.hero {
		background: linear-gradient(180deg, #1e3a8a 0%, #0f172a 100%);
		border-bottom-color: #334155;
	}
}

.hero-inner {
	max-width: 680px;
	margin: 0 auto;
}

.hero h1 {
	font-size: clamp(2.5rem, 6vw, 4rem);
	font-weight: 900;
	letter-spacing: -0.05em;
	line-height: 1.1;
	margin-bottom: 1.5rem;
	color: #0f172a;
}
@media (prefers-color-scheme: dark) {
	.hero h1 { color: #f8fafc; }
}

.gradient-text {
	background: linear-gradient(90deg, #3b82f6, #06b6d4);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-clip: text;
}

.hero-desc {
	font-size: 1.2rem;
	font-weight: 500;
	color: #475569;
	max-width: 540px;
	margin: 0 auto 2.5rem;
	line-height: 1.7;
}
@media (prefers-color-scheme: dark) {
	.hero-desc { color: #94a3b8; }
}

.hero-actions {
	display: flex;
	justify-content: center;
	gap: 1rem;
	flex-wrap: wrap;
}

.btn-primary {
	background: #0f172a;
	color: #fff;
	padding: 0.75rem 2rem;
	border-radius: 9999px;
	font-weight: 600;
	font-size: 1rem;
	text-decoration: none;
	transition: all 0.2s ease;
}
.btn-primary:hover {
	background: #1e293b;
	transform: translateY(-2px);
	box-shadow: 0 10px 15px -3px rgba(0,0,0,0.15);
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	.btn-primary { background: #f8fafc; color: #0f172a; }
	.btn-primary:hover { background: #e2e8f0; }
}

.btn-secondary {
	background: transparent;
	color: #475569;
	padding: 0.75rem 2rem;
	border-radius: 9999px;
	border: 1px solid #e2e8f0;
	font-weight: 600;
	font-size: 1rem;
	text-decoration: none;
	transition: all 0.2s ease;
}
.btn-secondary:hover {
	background: #f8fafc;
	text-decoration: none;
	transform: translateY(-2px);
}
@media (prefers-color-scheme: dark) {
	.btn-secondary { color: #94a3b8; border-color: #334155; }
	.btn-secondary:hover { background: #1e293b; color: #f8fafc; }
}

/* ── Main / Posts ───────────────────────────────────────────────── */
main {
	max-width: 1200px;
	margin: 0 auto;
	padding: 4rem 1.5rem 5rem;
}

.section-header {
	display: flex;
	align-items: baseline;
	justify-content: space-between;
	margin-bottom: 2rem;
}
.section-title {
	font-size: 1.8rem;
	font-weight: 800;
	letter-spacing: -0.03em;
	margin: 0;
}
.view-all {
	font-size: 0.9rem;
	font-weight: 600;
	color: var(--color-accent);
	text-decoration: none;
}
.view-all:hover { text-decoration: underline; }

/* ── Post Grid ──────────────────────────────────────────────────── */
.post-grid {
	list-style: none;
	padding: 0;
	margin: 0;
	display: grid;
	grid-template-columns: repeat(auto-fill, minmax(320px, 1fr));
	gap: 2rem;
}

.post-card {
	display: flex;
	flex-direction: column;
	height: 100%;
	background: var(--color-bg-card);
	border: 1px solid var(--color-border);
	border-radius: 16px;
	overflow: hidden;
	text-decoration: none;
	transition: all 0.3s cubic-bezier(0.25, 0.8, 0.25, 1);
	box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.05);
}
.post-card:hover {
	transform: translateY(-6px);
	box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.1);
	border-color: #93c5fd;
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	.post-card { box-shadow: 0 4px 6px -1px rgba(0, 0, 0, 0.3); }
	.post-card:hover { border-color: #3b82f6; box-shadow: 0 10px 15px -3px rgba(37, 99, 235, 0.15); }
}

.card-img {
	width: 100%;
	height: 160px;
	object-fit: cover;
	display: block;
	flex-shrink: 0;
}

.card-img-placeholder {
	width: 100%;
	height: 160px;
	background: var(--color-bg-secondary);
	border-bottom: 1px solid var(--color-border);
	display: flex;
	align-items: center;
	justify-content: center;
	flex-shrink: 0;
}
.card-emoji { font-size: 3rem; }

.card-body {
	padding: 1.25rem 1.5rem 1.5rem;
	display: flex;
	flex-direction: column;
	flex: 1;
	gap: 0.6rem;
}

.badge {
	display: inline-block;
	font-size: 0.75rem;
	font-weight: 700;
	padding: 0.25rem 0.75rem;
	border-radius: 9999px;
	width: fit-content;
}
.badge-cat {
	background: var(--color-accent-light);
	color: #2563eb;
	border: 1px solid var(--color-accent-border);
}
@media (prefers-color-scheme: dark) {
	.badge-cat { color: #60a5fa; }
}

.card-title {
	font-size: 1.05rem;
	font-weight: 700;
	color: var(--color-text-primary);
	line-height: 1.4;
	margin: 0;
	display: -webkit-box;
	-webkit-line-clamp: 2;
	-webkit-box-orient: vertical;
	overflow: hidden;
}
.post-card:hover .card-title { color: var(--color-accent); }

.card-desc {
	font-size: 0.875rem;
	color: var(--color-text-secondary);
	line-height: 1.6;
	margin: 0;
	flex: 1;
	display: -webkit-box;
	-webkit-line-clamp: 3;
	-webkit-box-orient: vertical;
	overflow: hidden;
}

.card-meta {
	font-size: 0.8rem;
	color: var(--color-text-muted);
	font-weight: 500;
	margin-top: auto;
	padding-top: 0.75rem;
	border-top: 1px solid var(--color-border);
}
</style>
