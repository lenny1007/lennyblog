---
import BaseHead from '../components/BaseHead.astro';
import Footer from '../components/Footer.astro';
import Header from '../components/Header.astro';
---

<!doctype html>
<html lang="zh-TW">
	<head>
		<BaseHead title="找不到頁面 | Lenny Chen" description="您要找的頁面不存在，可能已移除或網址有誤。" />
	</head>
	<body>
		<Header />
		<main>
			<div class="error-wrap">
				<p class="code">404</p>
				<h1>找不到這個頁面</h1>
				<p class="hint">這個網址不存在，可能已經移除或輸入有誤。</p>
				<div class="actions">
					<a href="/" class="btn-primary">回到首頁</a>
					<a href="/blog" class="btn-secondary">瀏覽所有文章</a>
				</div>
			</div>
		</main>
		<Footer />
	</body>
</html>

<style>
main {
	max-width: 860px;
	margin: 0 auto;
	padding: 8rem 1.5rem 10rem;
	text-align: center;
}

.error-wrap {
	display: flex;
	flex-direction: column;
	align-items: center;
	gap: 1rem;
}

.code {
	font-size: clamp(6rem, 20vw, 10rem);
	font-weight: 900;
	letter-spacing: -0.06em;
	line-height: 1;
	margin: 0;
	background: linear-gradient(90deg, #3b82f6, #06b6d4);
	-webkit-background-clip: text;
	-webkit-text-fill-color: transparent;
	background-clip: text;
}

h1 {
	font-size: clamp(1.5rem, 4vw, 2.2rem);
	font-weight: 800;
	color: var(--color-text-primary);
	margin: 0;
}

.hint {
	font-size: 1rem;
	color: var(--color-text-secondary);
	margin: 0;
}

.actions {
	display: flex;
	gap: 1rem;
	flex-wrap: wrap;
	justify-content: center;
	margin-top: 1.5rem;
}

.btn-primary {
	background: #0f172a;
	color: #fff;
	padding: 0.75rem 2rem;
	border-radius: 9999px;
	font-weight: 600;
	font-size: 1rem;
	text-decoration: none;
	transition: all 0.2s ease;
}
.btn-primary:hover {
	background: #1e293b;
	transform: translateY(-2px);
	box-shadow: 0 10px 15px -3px rgba(0, 0, 0, 0.15);
	text-decoration: none;
}
@media (prefers-color-scheme: dark) {
	.btn-primary { background: #f8fafc; color: #0f172a; }
	.btn-primary:hover { background: #e2e8f0; }
}

.btn-secondary {
	background: transparent;
	color: #475569;
	padding: 0.75rem 2rem;
	border-radius: 9999px;
	border: 1px solid var(--color-border);
	font-weight: 600;
	font-size: 1rem;
	text-decoration: none;
	transition: all 0.2s ease;
}
.btn-secondary:hover {
	background: var(--color-bg-secondary);
	text-decoration: none;
	transform: translateY(-2px);
}
@media (prefers-color-scheme: dark) {
	.btn-secondary { color: #94a3b8; }
	.btn-secondary:hover { color: #f8fafc; }
}
</style>
